msgid "Choose Postprocess Menu"
msgstr "选择后处理选单"

msgid "Choose Result (%zu)"
msgstr "选择结果（%zu项）"

msgid "... Recording ..."
msgstr "... 正在录音 ..."

msgid "... Recognizing ..."
msgstr "... 正在识别 ..."

msgid "... Postprocessing ..."
msgstr "... 正在后处理 ..."

msgid "Raw ASR"
msgstr "原始识别"

msgid "Command"
msgstr "命令"

msgid "Cancel"
msgstr "取消"

msgid "Option %zu"
msgstr "候选 %zu"

msgid " (%d/%d)"
msgstr "（%d/%d页）"

msgid " (Current)"
msgstr "（当前）"

msgid "Trigger Key"
msgstr "触发键"

msgid ""
"Press and hold this key to record. Release it to start recognition. "
"Supports regular keys, modifier keys, and modified key combinations. You "
"can configure multiple trigger keys. The config is stored at %s."
msgstr ""
"按住该键开始录音，松开后开始识别。支持普通按键、修饰键以及带修饰键的组合键。"
"可配置多个触发键。配置保存在 %s。"

msgid "Postprocess Menu Keys"
msgstr "后处理选单键"

msgid "Configure one or more keys to open the postprocess menu. The default is F9."
msgstr "可配置多个按键，用于打开后处理选单。默认是 F9。"

msgid "Previous Page Keys"
msgstr "上一页键"

msgid ""
"Keys for paging to the previous page in the postprocess menu and the "
"postprocess candidate menu. Defaults to Page Up and keypad Page Up."
msgstr "用于后处理选单和后处理候选菜单翻到上一页。默认是 Page Up 和小键盘 Page Up。"

msgid "Next Page Keys"
msgstr "下一页键"

msgid ""
"Keys for paging to the next page in the postprocess menu and the postprocess "
"candidate menu. Defaults to Page Down and keypad Page Down."
msgstr "用于后处理选单和后处理候选菜单翻到下一页。默认是 Page Down 和小键盘 Page Down。"

msgid "Open Vinput Settings"
msgstr "打开 Vinput 设置"

msgid "Default"
msgstr "默认"

msgid "Formal"
msgstr "正式"

msgid "Code"
msgstr "代码"

msgid "Translate"
msgstr "翻译"

msgid "Daemon is not running."
msgstr "守护进程未运行。"

msgid "Daemon status: %s"
msgstr "守护进程状态：%s"

msgid "Daemon started."
msgstr "守护进程已启动。"

msgid "Daemon stopped."
msgstr "守护进程已停止。"

msgid "Daemon restarted."
msgstr "守护进程已重启。"

msgid "Config value set."
msgstr "配置值已设置。"

msgid "Active"
msgstr "活跃"

msgid "Broken"
msgstr "损坏"

msgid "Installed"
msgstr "已安装"

msgid "No registry URL configured. Set with: vinput config set extra.registry_url <url>"
msgstr "未配置 registry URL。请使用以下命令设置：vinput config set extra.registry_url <url>"

msgid "installed"
msgstr "已安装"

msgid "available"
msgstr "可用"

msgid "Downloading %s..."
msgstr "正在下载 %s..."

msgid "Model '%s' installed successfully."
msgstr "模型 '%s' 安装成功。"

msgid "Run `vinput model use %s` to activate"
msgstr "运行 `vinput model use %s` 以启用该模型"

msgid "Model '%s' is not valid: %s"
msgstr "模型 '%s' 无效：%s"

msgid "Failed to save configuration."
msgstr "保存配置失败。"

msgid "Active model set to '%s'. Daemon restarted."
msgstr "活跃模型已设为 '%s'，守护进程已重启。"

msgid "Cannot remove active model '%s'. Use --force to override."
msgstr "不能移除活跃模型 '%s'，请用 --force。"

msgid "Model '%s' removed."
msgstr "模型 '%s' 已移除。"

msgid "Model '%s' not found at: %s"
msgstr "未找到模型 '%s'：%s"

msgid "Failed to read: %s"
msgstr "读取失败：%s"

msgid "Failed to parse vinput-model.json: %s"
msgstr "解析 vinput-model.json 失败：%s"

msgid "Name"
msgstr "名称"

msgid "Path"
msgstr "路径"

msgid "Size"
msgstr "大小"

msgid "No audio capture devices found or PipeWire is not running."
msgstr "未找到音频输入设备或 PipeWire 未运行。"

msgid "System Default"
msgstr "系统默认"

msgid "Device '%s' not found in PipeWire. Setting it anyway."
msgstr "在 PipeWire 中未找到设备 '%s'，仍将继续设置。"

msgid "Failed to save config."
msgstr "保存配置失败。"

msgid "Capture device set to '%s'. Restart daemon to apply changes."
msgstr "录音设备已设为 '%s'，请重启守护进程生效。"

msgid "No hotwords configured."
msgstr "未配置热词。"

msgid "Failed to open file: %s"
msgstr "打开文件失败：%s"

msgid "Loaded %zu hotwords."
msgstr "已加载 %zu 个热词。"

msgid "Cleared all hotwords."
msgstr "已清空所有热词。"

msgid "Failed to create temporary file for editing."
msgstr "创建临时文件失败，无法编辑。"

msgid "Editor exited with error."
msgstr "编辑器异常退出。"

msgid "Hotwords updated from editor."
msgstr "热词已从编辑器更新。"

msgid "yes"
msgstr "是"

msgid "no"
msgstr "否"

msgid "Scene '%s' added."
msgstr "场景 '%s' 已添加。"

msgid "Default scene set to '%s'."
msgstr "默认场景已设为 '%s'。"

msgid "Scene '%s' removed."
msgstr "场景 '%s' 已移除。"

msgid "Invalid scene type. Use: input | command | rewrite."
msgstr "场景类型无效，请使用：input | command | rewrite。"

msgid "Config already exists: %s"
msgstr "配置文件已存在：%s"

msgid "Created config: %s"
msgstr "已创建配置文件：%s"

msgid "Failed to create config"
msgstr "创建配置文件失败"

msgid "Model dir already exists: %s"
msgstr "模型目录已存在：%s"

msgid "Failed to create model dir: %s"
msgstr "创建模型目录失败：%s"

msgid "Created model dir: %s"
msgstr "已创建模型目录：%s"

msgid "Everything already initialized"
msgstr "所有文件已就绪，无需初始化"

msgid "LLM provider '%s' already exists."
msgstr "LLM 提供商 '%s' 已存在。"

msgid "LLM provider '%s' added."
msgstr "LLM 提供商 '%s' 已添加。"

msgid "LLM provider '%s' not found."
msgstr "LLM 提供商 '%s' 未找到。"

msgid "Active LLM provider set to '%s'."
msgstr "活跃 LLM 提供商已设为 '%s'。"

msgid "Cannot remove active provider '%s'. Use --force."
msgstr "不能移除活跃提供商 '%s'，请用 --force。"

msgid "LLM provider '%s' removed."
msgstr "LLM 提供商 '%s' 已移除。"

msgid "LLM is already enabled."
msgstr "LLM 已经是启用状态。"

msgid "LLM features are now ENABLED. Restart the daemon to apply."
msgstr "LLM 功能已启用，请重启守护进程生效。"

msgid "LLM is already disabled."
msgstr "LLM 已经是禁用状态。"

msgid "LLM features are now DISABLED. Restart the daemon to apply."
msgstr "LLM 功能已禁用，请重启守护进程生效。"
